# Telegram Bot API token from @BotFather
BOT_TOKEN=123456:ABCDEF

# MongoDB connection string (обязателен)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB=loan_wallet

# Публичный URL бота (обязателен для webhook)
# На Railway: https://your-app.up.railway.app
WEBHOOK_URL=https://your-app.up.railway.app

# Секрет для проверки входящих запросов от Telegram (рекомендуется)
WEBHOOK_SECRET=random_secret_string

# Логирование
RUST_LOG=loan_wallet=info
